# Public site URL (used in metadata, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://litigant.legal

# Google Tag Manager (loaded via @next/third-parties/google). Format: GTM-XXXXXXX
# Mounted only when set; leave empty to disable.
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 measurement ID (loaded via @next/third-parties/google). Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Google Sheets — service account credentials
# 1) Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# 2) Generate a JSON key, copy `client_email` and `private_key` from it
# 3) Share your target Sheet with that client_email (Editor role)
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...REPLACE_ME...==\n-----END PRIVATE KEY-----\n"

# Spreadsheet ID (the long token in the Sheet URL, between /d/ and /edit)
GOOGLE_SHEETS_ID=1AbCDEfGhIJkLmNopQRStuVwxyz1234567890

# Range for the contact form lead append. Default: Leads!A:J
# Columns: timestamp, name, position, company, industry, challenge, asset_value, contact, locale, page
GOOGLE_SHEETS_RANGE=Leads!A:J

# /analityka uses a static article list at src/data/articles.ts.
# OG tags (og:title, og:description, og:image) are parsed server-side from each URL
# and cached for 24h via unstable_cache. No Sheets/CMS env vars needed for it.
