# Public site URL (used in metadata, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://litigant.legal

# Google Tag Manager (loaded via @next/third-parties/google). Format: GTM-XXXXXXX
# Mounted only when set; leave empty to disable.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 measurement ID (loaded via @next/third-parties/google). Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Facebook Pixel ID (loaded via next/script afterInteractive; gated by cookie consent on en/ro).
NEXT_PUBLIC_FB_PIXEL_ID=

# LinkedIn Insight Tag — Partner ID (lazyOnload; gated by cookie consent on en/ro).
NEXT_PUBLIC_LI_PARTNER_ID=

# Microsoft Clarity Project ID (lazyOnload).
NEXT_PUBLIC_CLARITY_ID=

# Google Ads conversion tag — gtag id (e.g. AW-XXXXXXXXX) and conversion label.
NEXT_PUBLIC_GADS_ID=
NEXT_PUBLIC_GADS_CONVERSION_LABEL=

# CRM webhook — POST mirrors of the lead payload (Make / Zapier / Bitrix). Leave empty to disable.
CRM_WEBHOOK_URL=

# Resend (https://resend.com) — email notifications on every /api/lead and
# /api/lead-magnet submission. Domain `litigant.legal` must be verified in
# Resend (DNS records on NIC.UA). Leave empty to disable email notifications;
# Sheets append + CRM webhook continue to work.
RESEND_API_KEY=

# Override the recipient inbox (defaults to yuriy@litigant.legal).
LEAD_NOTIFY_EMAIL=

# SMTP (NIC.UA mail server) — used by /api/contact (the {name, phone, email,
# office, message} form). Office routing: kyiv → kyiv@, cc odesa@; odesa →
# odesa@, cc kyiv@. Both inboxes forward to Gmail via DirectAdmin Forwarders.
# These vars are ALSO required in Vercel envs (production). Never commit
# real values — keep them in .env.local (gitignored) for dev.
SMTP_HOST=mail.litigant.legal
SMTP_PORT=587
SMTP_USER=kyiv@litigant.legal
SMTP_PASS=
SMTP_FROM=kyiv@litigant.legal
# Optional inbox overrides (defaults are kyiv@/odesa@litigant.legal):
SMTP_INBOX_KYIV=
SMTP_INBOX_ODESA=

# Google Sheets — service account credentials
# 1) Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# 2) Generate a JSON key, copy `client_email` and `private_key` from it
# 3) Share your target Sheet with that client_email (Editor role)
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...REPLACE_ME...==\n-----END PRIVATE KEY-----\n"

# Spreadsheet ID (the long token in the Sheet URL, between /d/ and /edit)
GOOGLE_SHEETS_ID=1AbCDEfGhIJkLmNopQRStuVwxyz1234567890

# Range for the contact form lead append. Default: Leads!A:J
# Columns: timestamp, name, position, company, industry, challenge, asset_value, contact, locale, page
GOOGLE_SHEETS_RANGE=Leads!A:J

# /analityka uses a static article list at src/data/articles.ts.
# OG tags (og:title, og:description, og:image) are parsed server-side from each URL
# and cached for 24h via unstable_cache. No Sheets/CMS env vars needed for it.
